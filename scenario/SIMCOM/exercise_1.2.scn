# Exercise 1, scenario 2

# Loading plugins and settings
00:00:00.30>PLUGIN LOAD ADSBGUI
00:00:00.50>SHOWADSBPZ TRUE
#00:00:00.50>SHOWTRAF
00:00:00.50>ADSBCD TRUE
00:00:00.50>LABEL 2


# 1 CRE callsign, model, lat, lon, hdg, alt, spd
00:00:00.50>CRE ITA321, A320, N42'07'59.0", E011'55'39.0", 120, FL310, M0.80
00:00:00.50>ITA321 ORIG LFPG
00:00:00.50>ITA321 DEST LIBD
00:00:00.50>ITA321 ADDWPT NANUX,
00:00:00.50>ITA321 ADDWPT GOLPO,
00:00:00.50>ITA321 ADDWPT ALAXI,
00:00:00.50>ITA321 ADDWPT ERIKA,


# 2 Create aircraft
00:00:00.50>CRE RYR3747, A320, N42'06'24.0", E012'58'23.0", 260, FL340, M0.80
00:00:00.50>RYR3747 ORIG LBSF
00:00:00.50>RYR3747 DEST LIEE
#00:00:00.50>RYR3747 ADDWPT VELIM,
00:00:00.50>RYR3747 ADDWPT OKUNO,
00:00:00.50>RYR3747 ADDWPT ELITO,
00:00:00.50>RYR3747 ADDWPT RAVAL,
00:00:00.50>RYR3747 ADDWPT TINTO,


# 3 Create aircraft
00:00:00.50>CRE EZY1685, A320, N41'19'59.0", E013'04'59.0", 330, FL320, M0.78
00:00:00.50>EZY1685 ORIG LICA
00:00:00.50>EZY1685 DEST LFLL
00:00:00.50>EZY1685 ADDWPT CIRCE,
00:00:00.50>EZY1685 ADDWPT IDROX,
00:00:00.50>EZY1685 ADDWPT TOBIR,
00:00:00.50>EZY1685 ADDWPT MIKSO,
00:00:00.50>EZY1685 ADDWPT NANUX,
00:00:00.50>EZY1685 ADDWPT BIBEK,


