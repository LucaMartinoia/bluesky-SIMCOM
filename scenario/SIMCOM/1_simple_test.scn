# Example scenario

# Loading plugins and settings
00:00:00.30>PLUGIN LOAD ADSBGUI
00:00:00.50>SHOWADSBPZ TRUE
00:00:00.50>ADSBCD TRUE
00:00:00.50>SECURITY TOGGLE
00:00:00.50>ATTACK TOGGLE

# 1 CRE callsign, model, lat, lon, hdg, alt, spd
00:00:00.50>CRE ITA321, A320, N42'07'59.0", E011'55'39.0", 120, FL310, M0.80
00:00:00.50>ITA321 ORIG LFPG
00:00:00.50>ITA321 DEST LIBD
00:00:00.50>ITA321 ADDWPT NANUX,
00:00:00.50>ITA321 ADDWPT GOLPO,
00:00:00.50>ITA321 ADDWPT ALAXI,
00:00:00.50>ITA321 ADDWPT ERIKA,


# Turn on vertical and lateral autopilot VNAV/LNAV
00:00:00.55>ITA321 LNAV ON; ITA321 VNAV ON

# Speedup to focus point
00:00:00.55>PAN LIRF
#00:00:00.55>FF 50


